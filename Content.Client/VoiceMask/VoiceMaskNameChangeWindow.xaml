<controls:FancyWindow xmlns="https://spacestation14.io"
               xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
               Title="{Loc 'voice-mask-name-change-window'}"
               MinSize="5 30"
               SetWidth="360"> <!-- Forge-Change -->
    <BoxContainer Orientation="Vertical" Margin="5">
        <Label Name="NameInfoLabel" Text="{Loc 'voice-mask-name-change-info'}" /> <!-- Forge-Change -->
        <BoxContainer Name="NameContainer" Orientation="Horizontal" Margin="5"> <!-- Forge-Change -->
            <LineEdit Name="NameSelector" HorizontalExpand="True" />
            <Button Name="NameSelectorSet" Text="{Loc 'voice-mask-name-change-set'}" />
        </BoxContainer>
        <BoxContainer Name="SpeechVerbContainer" Orientation="Horizontal" Margin="5"> <!-- Forge-Change -->
            <Label Text="{Loc 'voice-mask-name-change-speech-style'}" />
            <OptionButton Name="SpeechVerbSelector" /> <!-- Populated in LoadVerbs -->
        </BoxContainer>
        <!-- Corvax-TTS-Start -->
        <BoxContainer Orientation="Vertical" Margin="5" Visible="False" Name="TTSContainer"> <!-- Forge-Change -->
            <Label Text="{Loc 'voice-mask-voice-change-info'}" />
            <ScrollContainer MinSize="0 155" MaxSize="340 155"> <!-- Forge-Change -->
                <ItemList Name="VoiceSelector" />
            </ScrollContainer>
        </BoxContainer>
        <!-- Corvax-TTS-End -->
    </BoxContainer>
</controls:FancyWindow>
